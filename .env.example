# Lessonforge configuration — copy to .env and edit

# Port the web app listens on
PORT=5364

# Instructor/admin password for the dashboard (change this!)
ADMIN_PASSWORD=change-me

# SQLite database location (uploads live next to it in ./data/uploads)
DB_PATH=./data/lessonforge.db

# Public base URL of this install — used for Stripe redirect URLs
# e.g. https://courses.yourdomain.com
BASE_URL=

# Optional: BYO Stripe secret key to sell courses via Stripe Checkout.
# Leave unset and paid checkout stays disabled (free/access-code enrollment
# still works). No platform cut — Stripe's standard fees only.
STRIPE_SECRET_KEY=
